.admin-container { padding: 40rpx; background: #f8fafc; min-height: 100vh; }
.dashboard-header { margin-bottom: 40rpx; }
.dashboard-header .title { font-size: 44rpx; font-weight: bold; color: #1e293b; }
.dashboard-header .date { font-size: 22rpx; color: #94a3b8; display: block; margin-top: 10rpx; }

/* 经理进度卡片网格 */
/* index.wxss / dashboard.wxss */

/* 1. 容器：确保允许换行，并使用 space-between 让对齐更美观 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between; /* 左右对齐，间隙留在中间 */
  padding: 0 5rpx; /* 给两侧留一点微小呼吸感 */
  margin-bottom: 60rpx;
}

/* 2. 卡片：宽度调整为略小于 50%，确保两张卡片 + 间距不超过 100% */
.manager-card { 
  width: 48%; /* 或者使用 calc(50% - 15rpx) */
  background: #fff;
  border-radius: 30rpx; 
  padding: 30rpx 10rpx; /* 减小左右内边距，给图表腾位 */
  margin-bottom: 20rpx; /* 纵向卡片间距 */
  box-sizing: border-box; 
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
}

/* 3. 微调内部图表大小，确保在半宽卡片里不拥挤 */
.chart-box { 
  width: 110rpx; 
  height: 110rpx; 
  position: relative; 
  margin-bottom: 15rpx; 
}

.manager-info .name { 
  font-size: 26rpx; /* 稍微缩小字号 */
  font-weight: bold;
  color: #334155;
}

.manager-info .detail, .manager-info .total {
  font-size: 20rpx;
}

/* 圆环逻辑 */
.chart-box { width: 120rpx; height: 120rpx; position: relative; margin-bottom: 20rpx; }
.circle-bg { width: 100%; height: 100%; border-radius: 50%; border: 10rpx solid #f1f5f9; position: absolute; }
.circle-active { 
  width: 100%; height: 100%; border-radius: 50%; 
  border: 10rpx solid #4f46e5; border-left-color: transparent; border-bottom-color: transparent;
  position: absolute; transition: transform 0.8s;
}
.circle-inner { 
  position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
  display: flex; justify-content: center; align-items: center; 
}
.percent { font-size: 24rpx; font-weight: bold; color: #334155; }

.manager-info .name { font-size: 28rpx; font-weight: bold; display: block; text-align: center; color: #334155; }
.manager-info .detail { font-size: 20rpx; color: #ef4444; display: block; margin-top: 10rpx; }
.manager-info .total { font-size: 20rpx; color: #94a3b8; display: block; }

/* 下部按钮区 */
.action-section { display: flex; flex-direction: column; gap: 24rpx; }
.action-card { 
  display: flex; align-items: center; padding: 40rpx; border-radius: 24rpx; background: #fff;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.02);
  border-left: 12rpx solid #e2e8f0; /* 默认边框 */
}

.action-card .icon { font-size: 50rpx; margin-right: 30rpx; }
.action-card .main { font-size: 30rpx; font-weight: bold; color: #1e293b; display: block; }
.action-card .sub { font-size: 22rpx; color: #94a3b8; margin-top: 6rpx; }

/* 状态颜色区分 */
.upload { border-left-color: #0ea5e9; } /* 蓝色 */
.import { border-left-color: #10b981; } /* 绿色 */
.kanban { border-left-color: #6366f1; } /* 紫色 */