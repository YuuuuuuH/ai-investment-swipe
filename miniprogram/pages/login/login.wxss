.login-page {
  height: 100vh;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  display: flex;
  justify-content: center;
  align-items: center;
}

.login-container {
  width: 80%;
  text-align: center;
}

.header { margin-bottom: 80rpx; }
.logo { font-size: 80rpx; margin-bottom: 20rpx; }
.title { font-size: 44rpx; color: #fff; font-weight: bold; letter-spacing: 4rpx; }
.desc { font-size: 20rpx; color: #64748b; margin-top: 10rpx; text-transform: uppercase; }

.form-box {
  background: rgba(255, 255, 255, 0.05);
  padding: 60rpx 40rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.input-group { text-align: left; margin-bottom: 40rpx; }
.label { font-size: 24rpx; color: #94a3b8; margin-left: 10rpx; }

.login-input {
  height: 90rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  margin-top: 16rpx;
  padding: 0 30rpx;
  color: #fff;
  font-size: 28rpx;
  border: 1rpx solid transparent;
}

.ph { color: #475569; }

.login-btn {
  background: #4f46e5;
  color: #fff;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 60rpx;
  box-shadow: 0 10rpx 30rpx rgba(79, 70, 229, 0.4);
}

.tips { margin-top: 30rpx; font-size: 22rpx; color: #475569; }
.footer-note { position: fixed; bottom: 60rpx; width: 100%; text-align: center; font-size: 20rpx; color: #334155; }