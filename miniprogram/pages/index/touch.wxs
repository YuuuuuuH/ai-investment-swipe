// touch.wxs 完整版
var startX = 0;
var startY = 0;

function touchstart(event, ownerInstance) {
  var index = event.currentTarget.dataset.index;
  if (index !== 0) return; // 🚑 关键：不是第一张就不响应

  var touch = event.touches[0] || event.changedTouches[0];
  startX = touch.pageX;
  startY = touch.pageY;
  event.instance.setStyle({ transition: 'none' });
}

function touchmove(event, ownerInstance) {
  var index = event.currentTarget.dataset.index;
  if (index !== 0) return; // 🚑 关键：不是第一张就不响应

  var touch = event.touches[0] || event.changedTouches[0];
  var deltaX = touch.pageX - startX;
  var deltaY = touch.pageY - startY;
  var rotate = deltaX / 15;

  event.instance.setStyle({
    transform: 'translate(' + deltaX + 'px, ' + deltaY + 'px) rotate(' + rotate + 'deg)'
  });
}

function touchend(event, ownerInstance) {
  var index = event.currentTarget.dataset.index;
  if (index !== 0) return; // 🚑 关键：不是第一张就不响应

  var touch = event.changedTouches[0];
  var deltaX = touch.pageX - startX;
  var deltaY = touch.pageY - startY;
  var instance = event.instance;
  var action = '';
  var dx = touch.pageX - startX; 
  var dy = touch.pageY - startY;

  if (Math.abs(dx) < 10 && Math.abs(dy) < 10) {
      return; 
    }
    
  if (deltaX > 100) { action = 'follow'; } 
  else if (deltaX < -100) { action = 'pass'; } 
  else if (deltaY < -100 && Math.abs(deltaX) < 80) { action = 'covered'; }

  if (action !== '') {
    var endX = action === 'follow' ? 800 : (action === 'pass' ? -800 : 0);
    var endY = action === 'covered' ? -800 : deltaY;
    instance.setStyle({
      transition: 'transform 0.4s ease-out',
      transform: 'translate(' + endX + 'px, ' + endY + 'px) rotate(' + (endX / 10) + 'deg)'
    });
    ownerInstance.callMethod('onCardSwipe', { action: action });
  } else {
    instance.setStyle({
      transition: 'transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275)',
      transform: 'translate(0px, 0px) rotate(0deg)'
    });
  }
}

module.exports = {
  touchstart: touchstart,
  touchmove: touchmove,
  touchend: touchend
};